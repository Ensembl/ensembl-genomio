{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.org/schemas/load_repeat.json",
  "description": "JSON schema for loading repeat features and optional consensus sequences for a single analysis+source. RepeatConsensus uniqueness is determined by (repeat_name, repeat_class, repeat_type, repeat_consensus) and referenced via an md5 key.",
  "type": "object",
  "additionalProperties": false,
  "required": ["analysis", "source", "repeat_features"],
  "properties": {
    "analysis": {
      "$ref": "load_common.json#/definitions/analysis",
      "description": "Single analysis definition for this load; loader resolves/creates analysis_id by logic_name."
    },

    "source": {
      "$ref": "load_common.json#/definitions/annotation_source",
      "description": "Single annotation source for this load; loader resolves/creates source_id by source_provider."
    },

    "repeat_consensus": {
      "type": "array",
      "items": { "$ref": "#/definitions/repeat_consensus" },
      "description": "Optional consensus entries. Each entry has an md5 key computed from (repeat_name, repeat_class, repeat_type, repeat_consensus)."
    },

    "repeat_features": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/repeat_feature" },
      "description": "Repeat features for this analysis+source."
    }
  },

  "definitions": {
    "md5_hex": {
      "type": "string",
      "pattern": "^[a-fA-F0-9]{32}$",
      "description": "32-char hex MD5 digest."
    },

    "repeat_consensus": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repeat_consensus_key", "repeat_name", "repeat_class", "repeat_type"],
      "properties": {
        "repeat_consensus_key": {
          "$ref": "#/definitions/md5_hex",
          "description": "MD5 key computed from (repeat_name, repeat_class, repeat_type, repeat_consensus) after whatever normalization the producer/loader defines (e.g. uppercase and whitespace-stripped for repeat_consensus)."
        },
        "repeat_name": {
          "$ref": "load_common.json#/definitions/non_empty_string",
          "maxLength": 255
        },
        "repeat_class": {
          "$ref": "load_common.json#/definitions/non_empty_string",
          "maxLength": 100
        },
        "repeat_type": {
          "$ref": "load_common.json#/definitions/non_empty_string",
          "maxLength": 40
        },
        "repeat_consensus": {
          "type": "string",
          "minLength": 1,
          "description": "repeat_consensus.repeat_consensus (consensus sequence)."
        }
      }
    },

    "repeat_consensus_ref": {
      "description": "Reference to consensus by md5 key; may be null if consensus unknown/not applicable.",
      "oneOf": [{ "type": "null" }, { "$ref": "#/definitions/md5_hex" }]
    },

    "repeat_feature": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "seq_region",
        "seq_region_start",
        "seq_region_end",
        "seq_region_strand",
        "repeat_start",
        "repeat_end"
      ],
      "properties": {
        "seq_region": {
          "$ref": "load_common.json#/definitions/non_empty_string",
          "description": "Seq_region name (chromosome/scaffold/contig). Loader resolves to seq_region_id."
        },

        "seq_region_start": { "$ref": "load_common.json#/definitions/positive_int" },
        "seq_region_end": { "$ref": "load_common.json#/definitions/positive_int" },
        "seq_region_strand": { "$ref": "load_common.json#/definitions/strand" },

        "repeat_start": {
          "$ref": "load_common.json#/definitions/positive_int",
          "description": "repeat_feature.repeat_start (on the consensus)."
        },
        "repeat_end": {
          "$ref": "load_common.json#/definitions/positive_int",
          "description": "repeat_feature.repeat_end (on the consensus)."
        },

        "repeat_consensus": {
          "$ref": "#/definitions/repeat_consensus_ref",
          "description": "Consensus md5 key (or null)."
        },

        "score": {
          "type": ["number", "null"],
          "description": "repeat_feature.score"
        },

        "attributes": {
          "type": "object",
          "additionalProperties": true,
          "description": "Tool-specific extras (e.g. divergence, motif, period, etc.)."
        }
      }
    }
  }
}
